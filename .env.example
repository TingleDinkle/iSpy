# Copy to .env and fill in real values. .env is gitignored — never commit it.

# AppstoreSpy API key (https://appstorespy.com)
APPSTORESPY_API_KEY=your-api-key-here

# PostgreSQL connection (SQLAlchemy URL, psycopg v3 driver)
# Local install:
DATABASE_URL=postgresql+psycopg://tracker:tracker@localhost:5432/appstore_tracker
# If you use the bundled `docker compose up -d db` database instead:
# DATABASE_URL=postgresql+psycopg://tracker:tracker@localhost:5433/appstore_tracker

# Alert delivery (optional). Discord: Server Settings -> Integrations ->
# Webhooks -> New Webhook -> Copy URL. Never commit this.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# --- Optional overrides (defaults shown) ---
# MONTHLY_CREDIT_BUDGET=100000
# CREDIT_SAFETY_FRACTION=0.95
# REQUESTS_PER_SECOND=2.0
# MAX_RETRIES=5
# BACKOFF_BASE_SECONDS=1.0
# BACKOFF_MAX_SECONDS=60.0
# REQUEST_TIMEOUT_SECONDS=30
# DEFAULT_COUNTRY=US
# PLAY_REVIEW_LANGUAGE=en_US
# REVIEWS_PAGE_SIZE=200
# SPIKE_THRESHOLD_PCT=50
# SPIKE_MA_WINDOW_DAYS=7
# SPIKE_MIN_BASELINE=1000
# INSTALLS_OUTLIER_MULTIPLIER=100   # x rolling median = data artifact, masked
# WATCH_REFRESH_DAYS=7              # watch-tier apps refresh at most this often
# RANK_TRACK_DEPTH=200              # chart depth stored per watch
# RANK_ENTRY_TOP=50                 # 'entered top N' event threshold
# RANK_CHURNY_ENTRY_TOP=10          # tighter bar for movers/new-release charts
# RANK_JUMP_MIN=20                  # positions gained for a rank_jump event
# SOFT_LAUNCH_MAX_COUNTRIES=15
# RATING_DROP_STARS=0.5             # 7d avg star drop that raises an alert
# RATING_MIN_REVIEWS=5
# TOPIC_SURGE_MIN=5
# TOPIC_SURGE_RATIO=3.0
